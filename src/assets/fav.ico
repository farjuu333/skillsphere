@charset "utf-8";

#ct-container { position: fixed; width: 100%; height: 100vh; top: 0px; left=
: 0px; z-index: 2000; display: flex; flex-direction: column; justify-conten=
t: space-between; pointer-events: none; }

.ct-row { display: flex; justify-content: space-between; }

.ct-group { flex: 1 1 0%; margin: 10px 20px; display: flex; flex-direction:=
 column; align-items: center; }

.ct-group:first-child { align-items: flex-start; }

.ct-group:last-child { align-items: flex-end; }

.ct-flex-bottom { justify-content: flex-end; }

.ct-toast { display: flex; justify-content: center; align-items: center; pa=
dding: 12px 20px; background-color: rgb(255, 255, 255); box-shadow: rgba(0,=
 0, 0, 0.15) 0px 4px 12px; color: rgb(0, 0, 0); border-radius: 4px; margin:=
 0px; opacity: 1; transition: 0.3s ease-in-out; min-height: 45px; pointer-e=
vents: all; }

.ct-toast:focus { outline: none; }

.ct-toast svg { min-width: 18px; }

.ct-cursor-pointer { cursor: pointer; }

.ct-icon-loading { display: inline-block; width: 20px; height: 20px; }

.ct-icon-loading::after { content: " "; display: block; width: 14px; height=
: 14px; margin: 1px; border-radius: 50%; border-width: 2px; border-style: s=
olid; border-image: initial; border-color: rgb(0, 136, 255) transparent; an=
imation: 1.2s linear 0s infinite normal none running ct-icon-loading; }

@keyframes ct-icon-loading {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.ct-text-group { margin-left: 15px; }

.ct-text-group-heading { margin-left: 25px; }

.ct-heading { font-size: 18px; margin: 0px 0px 5px; }

.ct-text { font-size: 14px; }

@media (max-width: 768px) {
  .ct-row { justify-content: flex-start; flex-direction: column; margin: 7p=
x 0px; }
  .ct-group { flex: 0 0 auto; margin: 0px; }
  .ct-toast { margin: 8px 15px; width: initial; }
}
