* { box-sizing: border-box; }

:root { --color-brand: #e91e63; --color-link: #1971c2; --color-brand-rgb: 2=
33, 30, 99; --color-black: #172b4d; --color-white: #ffffff; --color-gray-0:=
 #fbfbfb; --color-gray-1: #f4f5f7; --color-gray-2: #eaecef; --color-gray-3:=
 #cbcdd4; --color-gray-4: #808289; --sidebar-width: 18rem; --border-radius-=
md: 6px; }

html, body { margin: 0px; padding: 0px; font-family: -apple-system, BlinkMa=
cSystemFont, "Segoe UI", Helvetica, Arial, sans-serif, "Apple Color Emoji",=
 "Segoe UI Emoji"; color: var(--color-black); font-size: 16px; }

h1, h2, h3, h4, h5, h6, p, pre.astro-code { font-weight: 400; margin-top: 0=
px; margin-bottom: var(--space-2); padding-top: var(--space-1); }

.menu { height: 28px; width: 60px; position: relative; display: flex; align=
-items: center; cursor: pointer; background: none; border: 0px; text-align:=
 center; outline: none; color: transparent; }

.menu::before, .menu::after, .menu div { content: ""; position: absolute; w=
idth: 50px; height: 4px; background-color: var(--color-black); transition: =
0.3s; border-radius: 4px; }

.menu::before { top: 0px; }

.menu::after { bottom: 0px; }

.menu.active div { opacity: 0; }

.menu.active::before { transform: rotate(-45deg) translate3d(0px, -50%, 0px=
); top: 50%; }

.menu.active::after { transform: rotate(45deg) translate3d(0px, 50%, 0px); =
bottom: 50%; }

h1.main { font-size: 2.2rem; padding: 0px; }

p, pre.astro-code { margin-top: 0px; padding-top: 0px; }

pre.astro-code { border-radius: var(--border-radius-md); padding: var(--spa=
ce-2); position: relative; overflow: auto; }

pre.astro-code .prism-code--copy { position: absolute; top: 0px; right: 0px=
; padding: var(--space-1); color: var(--color-white); cursor: pointer; }

a { color: var(--color-link); text-decoration: none; }

a:focus, a:active { text-decoration: dashed; }

.rounded { border-radius: var(--border-radius-md); }

.sidebar, .container { width: 100%; height: 100%; min-height: 100vh; overfl=
ow-y: auto; }

.sidebar { max-width: var(--sidebar-width); position: fixed; background: va=
r(--color-gray-1); }

.search input { width: 100%; line-height: 1.8rem; font-size: 1.2rem; color:=
 var(--color-black); border-radius: var(--border-radius-md); border: 2px so=
lid var(--color-gray-3); background: var(--color-gray-2); outline: none; }

.search input::placeholder { opacity: 0.7; }

.search input:focus { border-color: rgba(var(--color-brand-rgb),.5); backgr=
ound: var(--color-gray-0); }

.search input:focus::placeholder { opacity: 0; }

.sidebar--links { margin: 0px; padding-right: ; padding-bottom: ; padding-l=
eft: ; padding-top: 0px; list-style-type: none; width: 100%; }

.sidebar--links li, .sidebar--links a { display: block; }

.sidebar--links a { line-height: 1.7rem; color: var(--color-black); border:=
 2px solid transparent; outline: none; transition: 0.1s; }

.sidebar--links a:focus { border-color: rgba(var(--color-brand-rgb),.5); ba=
ckground: rgba(var(--color-brand-rgb),.05); }

.sidebar--links a.active { border-color: transparent; background: var(--col=
or-gray-2); font-weight: 600; }

.container { padding-left: var(--sidebar-width); background: var(--color-gr=
ay-0); }

.brand a { display: flex; align-items: center; justify-content: center; fon=
t-size: 1.7rem; color: var(--color-brand); }

.brand a svg { width: 4rem; }

.brand a span { margin-left: var(--space-2); }

.brand .brand--navmenu { display: none; }

.iconset--info { margin-bottom: var(--space-2); }

.iconset--info td, .iconset--info th { padding: var(--space-1) 0; min-width=
: 85px; text-align: left; }

.icons { display: grid; grid-auto-rows: auto; grid-auto-columns: max-conten=
t; grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); column-gap:=
 var(--space-2); row-gap: var(--space-2); text-align: center; }

.icons .item { outline: none; }

.icons .item .icon { min-height: 64px; display: flex; align-items: center; =
justify-content: center; background: var(--color-white); border-radius: var=
(--border-radius-md); box-shadow: rgba(0, 0, 0, 0.1) 0px 1px 3px, rgba(0, 0=
, 0, 0.06) 0px 1px 2px; border: 2px solid transparent; font-size: 1.6em; }

.icons .item:hover .icon { background: var(--color-white); }

.icons .item:focus .icon { border-color: rgba(var(--color-brand-rgb),.5); b=
ackground: rgba(var(--color-brand-rgb),.05); }

.icons .item:focus .name { color: var(--color-brand); }

.icons .name { margin-top: 0.5rem; font-size: 0.7em; overflow: hidden; user=
-select: all; white-space: nowrap; }

@media (max-width: 719px) {
  .container, .sidebar { min-height: auto; width: 100%; max-width: 100%; po=
sition: relative; padding: 0px; }
  .sidebar { padding-top: var(--space-2); }
  .container > .p3 { padding: var(--space-2); }
  .brand { padding: 0 var(--space-2); display: flex; align-items: center; j=
ustify-content: space-between; }
  .brand .brand--navmenu { display: block; }
  .sidebar--links { display: none; }
  .sidebar--links.active { display: block; }
  .prism-code--copy { display: none; }
}

.icons:empty + .no-results::after { content: "No icons found"; }

.include-icon-sets .content { display: grid; grid-template-columns: repeat(=
auto-fill, minmax(250px, auto)); gap: 15px; }

.include-icon-sets .content .icon-set { color: var(--color-black); backgrou=
nd: var(--color-white); padding: 5px 8px 8px; border-radius: var(--border-r=
adius-md); box-shadow: rgba(0, 0, 0, 0.1) 0px 1px 3px, rgba(0, 0, 0, 0.06) =
0px 1px 2px; transition: background-color 0.15s; }

.include-icon-sets .content .icon-set:hover { background: rgb(243, 243, 243=
); }

.include-icon-sets .content .icon-set .name { font-size: 1.2rem; }

.include-icon-sets .content .icon-set .describe { font-size: 0.8rem; color:=
 var(--color-gray-4); }

.include-icon-sets .content .icon-set .samples { overflow: hidden; mask-ima=
ge: linear-gradient(90deg, rgb(255, 255, 255) 50%, transparent); font-size:=
 1.5rem; }

.include-icon-sets .content .icon-set .samples .box { margin-top: 7px; disp=
lay: grid; grid: 1fr / repeat(20, 1em); gap: 5px; }

html:has(.modal-root.active) { overflow: hidden; }

.modal-root { transition: all; animation-duration: 0.25s; }

.modal-root { display: block; }

.modal-root.hidden { display: none; }

.modal-root > .overlay { position: fixed; top: 0px; left: 0px; z-index: 100=
0; width: 100%; height: 100%; transition: 0.25s; touch-action: none; }

.modal-root > .overlay { background: rgba(0, 0, 0, 0.3); }

.modal-root > .overlay.appearing { background: rgba(0, 0, 0, 0.01); }

.modal-root > .modal-body { transition: 0.25s; position: fixed; top: 0px; z=
-index: 1001; width: 100%; max-width: 600px; height: 100%; background: var(=
--color-gray-0); padding: var(--space-3); overflow: hidden auto; }

.modal-root > .modal-body.open { right: 0px; }

.modal-root > .modal-body.close { right: -600px; }

.modal-root > .modal-body > .header { display: flex; align-items: center; j=
ustify-content: space-between; margin-bottom: var(--space-2); }

.modal-root > .modal-body > .header .title { margin: 0px; padding: 0px; fon=
t-size: 1.5rem; max-width: 90%; word-break: break-all; }

.modal-root > .modal-body > .header .close { cursor: pointer; touch-action:=
 none; font-size: 1.5rem; border-width: medium; border-style: none; border-=
color: currentcolor; border-image: initial; background: initial; padding: 1=
0px 20px; }

.icon-detail-modal-content .icon { text-align: center; min-height: 250px; p=
adding: 25px; }

.icon-detail-modal-content pre { overflow: auto; background-color: rgb(36, =
41, 46); color: rgb(225, 228, 232); padding: 10px; border-radius: 5px; }

.icon-detail-modal-content ul.copy { list-style: none; padding: 0px; }

.icon-detail-modal-content ul.copy li { margin-bottom: 0.5rem; }

.icon-detail-modal-content ul.copy li button { border-width: medium; border=
-style: none; border-color: currentcolor; border-image: initial; background=
: var(--color-gray-2); padding: 5px 7px; border-radius: 5px; cursor: pointe=
r; }

.icon-detail-modal-content ul.copy li button .text { margin-left: 5px; }

.icon-detail-modal-content .colors { margin: 1rem 0px; display: flex; gap: =
10px; flex-wrap: wrap; justify-content: center; }

.icon-detail-modal-content .colors button.item { flex: 0 0 30px; background=
: linear-gradient(to left top, transparent 50%, currentcolor 50%) rgb(0, 0,=
 0); color: rgb(255, 255, 255); width: 30px; height: 30px; display: block; =
font-size: 0px; border: var(--color-gray-2) 1px solid; border-radius: 100%;=
 }

.icon-detail-modal-content .colors button.item.active { border-width: 2px; =
border-color: var(--color-gray-4); }

@keyframes astroFadeInOut {=20
  0% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes astroFadeIn {=20
  0% { opacity: 0; mix-blend-mode: plus-lighter; }
  100% { opacity: 1; mix-blend-mode: plus-lighter; }
}

@keyframes astroFadeOut {=20
  0% { opacity: 1; mix-blend-mode: plus-lighter; }
  100% { opacity: 0; mix-blend-mode: plus-lighter; }
}

@keyframes astroSlideFromRight {=20
  0% { transform: translate(100%); }
}

@keyframes astroSlideFromLeft {=20
  0% { transform: translate(-100%); }
}

@keyframes astroSlideToRight {=20
  100% { transform: translate(100%); }
}

@keyframes astroSlideToLeft {=20
  100% { transform: translate(-100%); }
}

@media (prefers-reduced-motion) {
  ::view-transition-group(*), ::view-transition-old(*), ::view-transition-n=
ew(*) { animation: auto ease 0s 1 normal none running none !important; }
  [data-astro-transition-scope] { animation: auto ease 0s 1 normal none run=
ning none !important; }
}
